@model IEnumerable<PhotoSystem.Models.ApplicationUser>

@{
    ViewData["Title"] = "Підписники " + ViewBag.UserName;
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Users" asp-action="Index">Користувачі</a></li>
            <li class="breadcrumb-item active">Підписники @ViewBag.UserName</li>
        </ol>
    </nav>

    <h2 class="mb-4">На @ViewBag.UserName підписані (@Model.Count()):</h2>

    <div class="list-group shadow-sm">
        @if (!Model.Any())
        {
            <div class="list-group-item text-center py-4 text-muted">
                У цього користувача поки немає підписників.
            </div>
        }
        @foreach (var user in Model)
        {
            <a asp-controller="Users" asp-action="Profile" asp-route-id="@user.Id"
               class="list-group-item list-group-item-action d-flex align-items-center justify-content-between p-3">
                <div class="d-flex align-items-center">
                    <img src="https://ui-avatars.com/api/?name=@user.Email&background=random&size=45"
                         class="rounded-circle me-3" alt="Avatar">
                    <span class="fw-bold">@user.Email</span>
                </div>
                <span class="btn btn-sm btn-outline-primary">Переглянути профіль</span>
            </a>
        }
    </div>
</div>