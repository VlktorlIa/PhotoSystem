@using Microsoft.AspNetCore.Identity

@using PhotoSystem.Models

@inject SignInManager<ApplicationUser> SignInManager

@inject UserManager<ApplicationUser> UserManager



<!DOCTYPE html>

<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - PhotoSystem</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/PhotoSystem.styles.css" asp-append-version="true" />

</head>

<body>

    <header>

        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">

            <div class="container-fluid">

                <a class="navbar-brand fw-bold text-primary" asp-controller="Feed" asp-action="Index">PhotoSystem</a>



                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target=".navbar-collapse">

                    <span class="navbar-toggler-icon"></span>

                </button>



                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1">

                        <li class="nav-item">

                            <a class="nav-link text-dark @(ViewContext.RouteData.Values["controller"]?.ToString() == "Feed" ? "active fw-bold" : "")"
                               asp-controller="Feed" asp-action="Index">Стрічка</a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link text-dark @(ViewContext.RouteData.Values["action"]?.ToString() == "MyPosts" ? "active fw-bold" : "")"
                               asp-controller="Photos" asp-action="MyPosts">Мої фото</a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link text-dark @(ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active fw-bold" : "")"
                               asp-controller="Photos" asp-action="Create">Опублікувати</a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link text-dark @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active fw-bold" : "")"
                               asp-controller="Users" asp-action="Index">Користувачі</a>

                        </li>

                    </ul>



                    <div class="d-flex align-items-center">

                        @if (SignInManager.IsSignedIn(User))

                        {

                            var currentUser = await UserManager.GetUserAsync(User);

                            <div class="me-3">

                                <a asp-controller="Users" asp-action="Profile" asp-route-id="@currentUser?.Id"
                                       class="d-flex align-items-center text-decoration-none text-dark hover-opacity">

                                    <img src="https://ui-avatars.com/api/?name=@(User.Identity.Name)&background=random&size=35"
                                         class="rounded-circle border me-2" alt="Avatar">

                                    <span class="d-none d-md-inline small fw-bold">Мій профіль</span>

                                </a>

                            </div>

                        }

                        <partial name="_LoginPartial" />

                    </div>

                </div>

            </div>

        </nav>

    </header>



    <div class="container">

        <main role="main" class="pb-3">

            @RenderBody()

        </main>

    </div>



    <footer class="border-top footer text-muted">

        <div class="container">

            &copy; 2025 - PhotoSystem

        </div>

    </footer>



    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>



    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>