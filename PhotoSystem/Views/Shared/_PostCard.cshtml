@model PhotoSystem.Models.PhotoPost
@using Microsoft.AspNetCore.Identity
@inject UserManager<PhotoSystem.Models.ApplicationUser> UserManager
@inject PhotoSystem.Data.ApplicationDbContext Context
@using Microsoft.EntityFrameworkCore

@{
    var currentUserId = UserManager.GetUserId(User);
    var interaction = Context.PostInteractions
        .Include(i => i.OriginalAuthor)
        .FirstOrDefault(i => i.ReplyPostId == Model.Id);
}

<div class="card mb-5 shadow-sm border-0 rounded-3 overflow-hidden animate__animated animate__fadeInUp" id="post-@Model.Id">
    @if (interaction != null)
    {
        var isReply = interaction.Type == PhotoSystem.Models.InteractionType.Reply;
        var badgeClass = isReply ? "bg-success bg-opacity-10 text-success border-success border-opacity-25" : "bg-info bg-opacity-10 text-info border-info border-opacity-25";
        var icon = isReply ? "💬 Відповідь для:" : "✈️ Переслано від:";

        <div class="p-2 px-3 border-bottom d-flex align-items-center justify-content-between @badgeClass">
            <small class="fw-bold">@icon @interaction.OriginalAuthor?.Email</small>
            <a asp-controller="Photos" asp-action="Details" asp-route-id="@interaction.OriginalPostId"
                   class="btn btn-sm btn-link text-decoration-none p-0 fw-bold" style="font-size: 0.75rem;">
                Переглянути оригінал →
            </a>
        </div>
    }

    <div class="card-header bg-white border-0 py-3 d-flex align-items-center">
        <a asp-controller="Users" asp-action="Profile" asp-route-id="@Model.UserId" class="text-decoration-none d-flex align-items-center text-dark">
            <img src="https://ui-avatars.com/api/?name=@Model.User?.Email&background=random&size=40" class="rounded-circle me-3">
            <span class="fw-bold">@Model.User?.Email</span>
        </a>
    </div>

    <div class="bg-light text-center">
        <img src="@Model.ImagePath" class="img-fluid" style="max-height: 600px; width: auto; object-fit: contain;">
    </div>

    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between mb-3">
            <div class="fs-5 d-flex align-items-center gap-3">
                <strong title="Вподобання">❤️ @(Model.Likes?.Count ?? 0)</strong>
                <span class="text-muted" style="font-size: 0.9rem;">💬 @(Context.Comments.Count(c => c.PhotoPostId == Model.Id))</span>
            </div>
            
            <div class="d-flex gap-2">
                @if (Model.UserId != currentUserId)
                {
                    <button type="button" class="btn btn-sm btn-outline-info" onclick="openForwardModal(@Model.Id)">✈️ Переслати</button>
                    <button type="button" class="btn btn-sm btn-outline-success" onclick="openReplyModal(@Model.Id)">💬 Відповісти</button>
                }
                
                @{
                    var userLike = Model.Likes?.FirstOrDefault(l => l.UserId == currentUserId);
                }
                <form asp-controller="Photos" asp-action="ToggleLike" method="post" class="m-0">
                    <input type="hidden" name="postId" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@(ViewContext.HttpContext.Request.Path + "#post-" + Model.Id)"  />
                    <button type="submit" class="btn btn-sm @(userLike != null ? "btn-danger" : "btn-outline-primary")">
                        @(userLike != null ? "💔 Прибрати лайк" : "👍 Лайк")
                    </button>
                </form>
            </div>
        </div>
        <p class="card-text mb-1"><span class="fw-bold me-1">@Model.User?.Email</span> @Model.Description</p>
        <small class="text-muted">@Model.CreatedAt.ToString("dd MMMM yyyy HH:mm")</small>
    </div>
</div>